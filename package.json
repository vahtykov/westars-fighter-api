{
  "name": "fighter-project",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "build:api": "turbo run build --filter=@fighter/api",
    "build:admin": "turbo run build --filter=@fighter/admin",
    "dev:api": "turbo run dev --filter=@fighter/api",
    "dev:admin": "turbo run dev --filter=@fighter/admin"
  },
  "devDependencies": {
    "rimraf": "^5.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "packageManager": "yarn@4.5.3"
}
